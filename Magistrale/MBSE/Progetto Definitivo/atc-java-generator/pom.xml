<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">

	<modelVersion>4.0.0</modelVersion>

	<!-- meglio se è tipo package Java (convenzione Maven), ma non è
	obbligatorio -->
	<groupId>atc-mbse</groupId>
	<artifactId>atc-java-generator</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<packaging>jar</packaging>

	<name>ATC Java Generator</name>

	<properties>
		<!-- elimina i warning “Using platform encoding … build is platform
		dependent!” -->
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<!-- modo raccomandato per fissare la versione Java quando possibile -->
		<maven.compiler.release>8</maven.compiler.release>
	</properties>

	<!-- dipendenza “di test” solo per far comparire chiaramente Maven
	Dependencies -->
	<dependencies>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter</artifactId>
			<version>5.14.2</version>
			<scope>test</scope>
		</dependency>
	</dependencies>

</project>
